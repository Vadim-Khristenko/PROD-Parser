# Telegram API credentials
TG_API_ID=
TG_API_HASH=
TG_PHONE=
TG_PASSWORD=

# Optional defaults for tg-fetch
TG_ACCOUNT=acc1
TG_PEER=@my_channel
TG_STATE_DIR=./data

# OpenAI-compatible LLM settings
LLM_ENABLE=false
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=

# Routing: single|per-task
LLM_ROUTING_MODE=single

# Base/default model
LLM_MODEL=gpt-4o-mini

# Optional per-task models (used when LLM_ROUTING_MODE=per-task)
LLM_MODEL_PERSONA=
LLM_MODEL_TOPICS=
LLM_MODEL_RELATIONS=
LLM_MODEL_MINDMAP=

# Optional deep persona model used with --llm-dig-deeper
LLM_DIG_DEEPER_MODEL=
LLM_DIG_DEEPER=false

# Optional model metadata source
# Absolute URL example: https://api.example.com/v1/models/info
# Relative URL example (joined with LLM_BASE_URL): /models/info
LLM_MODEL_INFO_URL=
# Local JSON file with model capacities
LLM_MODEL_INFO_FILE=

# Default token capacities (used when model metadata is absent)
LLM_INPUT_TOKENS=32000
LLM_OUTPUT_TOKENS=2048
LLM_SAFETY_TOKENS=512
LLM_MIN_OUTPUT_TOKENS=256

# LLM request controls
LLM_BATCH_MESSAGES=250
LLM_TIMEOUT_MS=45000
LLM_RETRY_MAX=2
LLM_TEMPERATURE=0.2

# Optional persistent polling mode for tg-fetch
TG_POLL=false
TG_POLL_WITH_BACKFILL=true
TG_POLL_INTERVAL_MS=5000
TG_MAX_INFO=false
TG_CMD_POLICY=owner
TG_CMD_IDS=
TG_CMD_PREFIX=/
TG_SEARCH_LIMIT=7
TG_OWNER_ID=
TG_OWNER_USERNAME=

# JSONL segmentation
JSONL_FILE_MAX_MESSAGES=5000

# Logging (pretty console + JSON file)
LOG_LEVEL=info
LOG_CONSOLE_ENABLED=true
LOG_CONSOLE_PRETTY=true
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./logs/prod-parser.log

# analyze-all defaults
ANALYZE_PROFILE=full
ANALYZE_PRETTY=true
ANALYZE_PARTICIPANTS=true
ANALYZE_RECENT_MESSAGES=300
ANALYZE_WITH_SCHEMA=true
ANALYZE_SCHEMA_OUT=
ANALYZE_HEARTBEAT_SEC=20

# schema command defaults
SCHEMA_OUT=./data/exports/schemas
SCHEMA_PRETTY=true
